<% if user.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm" role="alert">
    <p class="font-semibold mb-1"><%= pluralize(user.errors.count, "error") %> prevented this record from saving:</p>
    <ul class="list-disc list-inside space-y-0.5 text-red-600">
      <% user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-5">
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :name, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.email_field :email, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <% if user.persisted? %>
      <p class="text-slate-400 text-xs mb-1.5">Leave blank to keep current password.</p>
    <% end %>
    <%= f.password_field :password,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.password_field :password_confirmation,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>
</div>

<div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-200">
  <%= f.submit class: "bg-amber-600 hover:bg-amber-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
  <%= link_to "Cancel", users_path, class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
</div>
