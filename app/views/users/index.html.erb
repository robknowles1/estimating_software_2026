<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle") %></p>
  </div>
  <%= link_to new_user_path,
      class: "inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
    </svg>
    <%= t(".add_button") %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @users.any? %>
    <table class="min-w-full">
      <thead>
        <tr class="border-b border-slate-200 bg-slate-50">
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= User.human_attribute_name(:name) %></th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= User.human_attribute_name(:email) %></th>
          <th class="px-6 py-3.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each do |user| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center flex-shrink-0">
                  <span class="text-white text-xs font-bold"><%= user.name.first.upcase %></span>
                </div>
                <span class="text-sm font-medium text-slate-900"><%= user.name %></span>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= user.email %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to t("common.edit"), edit_user_path(user),
                  class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5.356-3.779M9 20H4v-2a4 4 0 015.356-3.779M15 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </div>
      <p class="text-slate-700 font-medium text-sm"><%= t(".empty_title") %></p>
      <p class="text-slate-400 text-sm mt-1"><%= t(".empty_description") %></p>
    </div>
  <% end %>
</div>
