<div class="max-w-lg">
  <div class="mb-6">
    <%= link_to users_path,
        class: "inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 transition-colors mb-4" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Users
    <% end %>
    <h1 class="text-2xl font-bold text-slate-900">New User</h1>
    <p class="text-slate-500 text-sm mt-1">Add a new user to the estimating tool.</p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
    <%= form_with model: @user, url: users_path do |f| %>
      <%= render "form", user: @user, f: f %>
    <% end %>
  </div>
</div>
