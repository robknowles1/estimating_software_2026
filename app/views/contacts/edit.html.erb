<div class="mb-8">
  <div class="text-sm text-slate-500 mb-1">
    <%= link_to @client.company_name, client_path(@client), class: "hover:text-amber-700 transition-colors" %>
  </div>
  <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
  <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle", name: "#{@contact.first_name} #{@contact.last_name}") %></p>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8 max-w-2xl">
  <%= form_with model: [ @client, @contact ] do |f| %>
    <%= render "form", f: f, contact: @contact %>
  <% end %>
</div>
