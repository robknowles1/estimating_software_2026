<% if contact.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm" role="alert">
    <p class="font-semibold mb-1">
      <%= t("contacts.form.errors", count: contact.errors.count) %>
    </p>
    <ul class="list-disc list-inside space-y-0.5 text-red-600">
      <% contact.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="grid grid-cols-2 gap-5">
  <div>
    <%= f.label :first_name, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :first_name, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div>
    <%= f.label :last_name, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :last_name, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>
</div>

<div class="mt-5">
  <%= f.label :title, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
  <%= f.text_field :title,
      class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
</div>

<div class="grid grid-cols-2 gap-5 mt-5">
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.email_field :email,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div>
    <%= f.label :phone, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.telephone_field :phone,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>
</div>

<div class="mt-5">
  <label class="flex items-center gap-2.5 cursor-pointer">
    <%= f.check_box :is_primary,
        class: "w-4 h-4 rounded border-slate-300 text-amber-600 focus:ring-amber-500 cursor-pointer" %>
    <span class="text-sm font-medium text-slate-700"><%= Contact.human_attribute_name(:is_primary) %></span>
  </label>
</div>

<div class="mt-5">
  <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
  <%= f.text_area :notes, rows: 3,
      class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
</div>

<div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-200">
  <%= f.submit class: "bg-amber-600 hover:bg-amber-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
  <%= link_to t("contacts.form.cancel"), client_path(@client), class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
</div>
