<div class="w-full max-w-sm">

  <%# Mobile-only header (hidden on lg where left panel shows) %>
  <div class="lg:hidden mb-8 text-center">
    <span class="text-amber-600 text-xs font-semibold uppercase tracking-widest">Trim-Art</span>
    <h1 class="text-slate-900 text-2xl font-bold mt-1">Project Estimating Tool</h1>
  </div>

  <h2 class="text-slate-900 text-2xl font-bold mb-1">Sign in</h2>
  <p class="text-slate-500 text-sm mb-8">Enter your credentials to continue.</p>

  <% if alert %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm flex items-center gap-2" role="alert">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 110 18A9 9 0 0112 3z"/>
      </svg>
      <%= alert %>
    </div>
  <% end %>

  <%= form_with url: session_path, method: :post, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.email_field :email, required: true, autofocus: true,
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.password_field :password, required: true,
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>

    <%= f.submit "Sign In",
        class: "w-full bg-amber-600 hover:bg-amber-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm transition-colors cursor-pointer mt-2" %>
  <% end %>

</div>
