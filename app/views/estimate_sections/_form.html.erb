<% if section.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm" role="alert">
    <p class="font-semibold mb-1">
      <%= t("estimate_sections.form.errors", count: section.errors.count) %>
    </p>
    <ul class="list-disc list-inside space-y-0.5 text-red-600">
      <% section.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-5">
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :name, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :quantity, t("estimate_sections.form.quantity_label"), class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.number_field :quantity, min: 0.01, step: "any",
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
    <div>
      <%= f.label :default_markup_percent, t("estimate_sections.form.markup_label"), class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.number_field :default_markup_percent, min: 0, max: 999.99, step: 0.01,
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
  </div>
</div>

<div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-200">
  <%= f.submit class: "bg-amber-600 hover:bg-amber-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
  <%= link_to t("estimate_sections.form.cancel"), edit_estimate_path(@estimate), class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
</div>
