<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle") %></p>
  </div>
  <%= link_to new_client_path,
      class: "inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
    </svg>
    <%= t(".add_button") %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @clients.any? %>
    <table class="min-w-full">
      <thead>
        <tr class="border-b border-slate-200 bg-slate-50">
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= Client.human_attribute_name(:company_name) %></th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t(".primary_contact_header") %></th>
          <th class="px-6 py-3.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @clients.each do |client| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <%= link_to client.company_name, client_path(client),
                  class: "text-sm font-medium text-slate-900 hover:text-amber-700 transition-colors" %>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">
              <% if client.primary_contact %>
                <%= "#{client.primary_contact.first_name} #{client.primary_contact.last_name}" %>
              <% else %>
                <span class="text-slate-300">&mdash;</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to t("common.edit"), edit_client_path(client),
                  class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
      <p class="text-slate-700 font-medium text-sm"><%= t(".empty_title") %></p>
      <p class="text-slate-400 text-sm mt-1"><%= t(".empty_description") %></p>
      <%= link_to t(".add_button"), new_client_path,
          class: "mt-4 inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" %>
    </div>
  <% end %>
</div>
