<%# Client header %>
<div class="flex items-start justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= @client.company_name %></h1>
    <% if @client.address.present? %>
      <p class="text-slate-500 text-sm mt-0.5"><%= @client.address %></p>
    <% end %>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to t("common.edit"), edit_client_path(@client),
        class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium border border-slate-300 rounded-lg px-3 py-2 transition-colors" %>
    <%= button_to t("common.delete"), client_path(@client), method: :delete,
        class: "inline-flex items-center gap-1.5 text-red-600 hover:text-red-700 text-sm font-medium border border-red-200 hover:border-red-300 rounded-lg px-3 py-2 transition-colors bg-white",
        data: { turbo_confirm: t("clients.show.confirm_delete", name: @client.company_name) } %>
  </div>
</div>

<%# Notes %>
<% if @client.notes.present? %>
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
    <h2 class="text-sm font-semibold text-slate-700 mb-2"><%= t("clients.show.notes_heading") %></h2>
    <p class="text-sm text-slate-600 whitespace-pre-line"><%= @client.notes %></p>
  </div>
<% end %>

<%# Contacts section %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200">
    <h2 class="text-base font-semibold text-slate-900"><%= t("clients.show.contacts_heading") %></h2>
    <%= link_to new_client_contact_path(@client),
        class: "inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-3 py-1.5 rounded-lg text-sm font-semibold transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      <%= t("clients.show.add_contact") %>
    <% end %>
  </div>

  <% if @contacts.any? %>
    <table class="min-w-full">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t("clients.show.name_header") %></th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= Contact.human_attribute_name(:title) %></th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= Contact.human_attribute_name(:email) %></th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= Contact.human_attribute_name(:phone) %></th>
          <th class="px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @contacts.each do |contact| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-900"><%= "#{contact.first_name} #{contact.last_name}" %></span>
                <% if contact.is_primary? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800"><%= t("clients.show.primary_badge") %></span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= contact.title.presence || "&mdash;".html_safe %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= contact.email.presence || "&mdash;".html_safe %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= contact.phone.presence || "&mdash;".html_safe %></td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to t("common.edit"), edit_client_contact_path(@client, contact),
                    class: "text-slate-600 hover:text-amber-700 text-sm font-medium transition-colors" %>
                <%= button_to t("common.delete"), client_contact_path(@client, contact), method: :delete,
                    class: "text-red-500 hover:text-red-700 text-sm font-medium transition-colors bg-transparent border-0 p-0 cursor-pointer",
                    data: { turbo_confirm: t("contacts.confirm_delete") } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="flex flex-col items-center justify-center py-12 text-center">
      <p class="text-slate-500 text-sm"><%= t("clients.show.no_contacts") %></p>
      <%= link_to t("clients.show.add_contact"), new_client_contact_path(@client),
          class: "mt-3 text-sm text-amber-600 hover:text-amber-700 font-medium transition-colors" %>
    </div>
  <% end %>
</div>
