<div class="mb-8">
  <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
  <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle", name: @client.company_name) %></p>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8 max-w-2xl">
  <%= form_with model: @client do |f| %>
    <%= render "form", f: f, client: @client %>
  <% end %>
</div>
