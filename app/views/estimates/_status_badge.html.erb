<%
  badge_classes = case status
  when "draft"    then "bg-slate-100 text-slate-700"
  when "sent"     then "bg-blue-100 text-blue-700"
  when "approved" then "bg-green-100 text-green-700"
  when "lost"     then "bg-red-100 text-red-700"
  when "archived" then "bg-slate-100 text-slate-500"
  else "bg-slate-100 text-slate-700"
  end
%>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge_classes %>">
  <%= t("estimates.index.status_#{status}") %>
</span>
