<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle", estimate: @estimate.estimate_number) %></p>
  </div>
  <%= link_to t(".back_to_estimate"), edit_estimate_path(@estimate),
      class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium border border-slate-300 rounded-lg px-3 py-2 transition-colors" %>
</div>

<%= form_with url: estimate_materials_path(@estimate), method: :patch do |f| %>
  <% @materials_by_category.each do |category, materials| %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mb-6">
      <div class="px-6 py-3 border-b border-slate-200 bg-slate-50">
        <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide"><%= t("estimate_materials.category.#{category}") %></h2>
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100 text-xs text-slate-500">
            <th class="px-6 py-2 text-left font-medium w-16"><%= t("estimate_materials.slot_label") %></th>
            <th class="px-6 py-2 text-left font-medium"><%= t("estimate_materials.description_label") %></th>
            <th class="px-6 py-2 text-left font-medium w-36"><%= t("estimate_materials.price_label") %></th>
            <th class="px-6 py-2 text-left font-medium w-32"><%= t("estimate_materials.unit_label") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% materials.each do |material| %>
            <tr>
              <td class="px-6 py-2 font-mono text-xs font-semibold text-slate-600"><%= material.slot_label %></td>
              <td class="px-6 py-2">
                <%= text_field_tag "estimate_materials[#{material.id}][description]",
                    material.description,
                    placeholder: t("estimate_materials.description_placeholder"),
                    class: "w-full border border-slate-200 rounded px-2.5 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
              </td>
              <td class="px-6 py-2">
                <%= number_field_tag "estimate_materials[#{material.id}][price_per_unit]",
                    material.price_per_unit,
                    step: "any", min: 0,
                    class: "w-full border border-slate-200 rounded px-2.5 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
              </td>
              <td class="px-6 py-2">
                <%= text_field_tag "estimate_materials[#{material.id}][unit]",
                    material.unit,
                    placeholder: t("estimate_materials.unit_placeholder"),
                    class: "w-full border border-slate-200 rounded px-2.5 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= submit_tag t(".save_button"),
        class: "bg-amber-600 hover:bg-amber-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
    <%= link_to t(".cancel"), edit_estimate_path(@estimate),
        class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
  </div>
<% end %>
