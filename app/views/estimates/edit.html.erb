<%# Estimate header %>
<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-bold text-slate-900"><%= @estimate.title %></h1>
      <%= render "status_badge", status: @estimate.status %>
    </div>
    <p class="text-slate-500 text-sm">
      <%= @estimate.estimate_number %> &middot;
      <%= link_to @estimate.client.company_name, client_path(@estimate.client), class: "hover:text-amber-700 transition-colors" %>
    </p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to t("estimates.edit.materials_link"), edit_estimate_materials_path(@estimate),
        class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium border border-slate-300 rounded-lg px-3 py-2 transition-colors" %>
    <%= link_to t("estimates.edit.back"), estimates_path,
        class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium border border-slate-300 rounded-lg px-3 py-2 transition-colors" %>
    <%= button_to t("common.delete"), estimate_path(@estimate), method: :delete,
        class: "inline-flex items-center gap-1.5 text-red-600 hover:text-red-700 text-sm font-medium border border-red-200 hover:border-red-300 rounded-lg px-3 py-2 transition-colors bg-white",
        data: { turbo_confirm: t("estimates.edit.confirm_delete", number: @estimate.estimate_number) } %>
  </div>
</div>

<div class="grid grid-cols-3 gap-6">
  <%# Metadata / edit form %>
  <div class="col-span-1">
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("estimates.edit.details_heading") %></h2>
      <%= form_with model: @estimate do |f| %>
        <%= render "form", f: f, estimate: @estimate %>
      <% end %>
    </div>

    <%# Status form (status-only update) %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("estimates.edit.status_heading") %></h2>
      <%= form_with url: estimate_path(@estimate), method: :patch do |f| %>
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.select :status,
              Estimate.statuses.keys.map { |s| [ t("estimates.index.status_#{s}"), s ] },
              { selected: @estimate.status },
              name: "estimate[status]",
              class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
        </div>
        <%# hidden fields to satisfy validations %>
        <%= hidden_field_tag "estimate[title]", @estimate.title %>
        <%= hidden_field_tag "estimate[client_id]", @estimate.client_id %>
        <div class="mt-4">
          <%= f.submit t("estimates.edit.update_status"), class: "w-full bg-slate-700 hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%# Job settings form %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("estimates.edit.job_settings_heading") %></h2>
      <%= form_with url: estimate_path(@estimate), method: :patch do |f| %>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1"><%= t("estimates.edit.miles_to_jobsite") %></label>
            <%= text_field_tag "estimate[miles_to_jobsite]", @estimate.miles_to_jobsite,
                type: :number, step: "any", min: 0,
                class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t("estimates.edit.installer_crew_size") %></label>
              <%= text_field_tag "estimate[installer_crew_size]", @estimate.installer_crew_size,
                  type: :number, step: 1, min: 1,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t("estimates.edit.delivery_crew_size") %></label>
              <%= text_field_tag "estimate[delivery_crew_size]", @estimate.delivery_crew_size,
                  type: :number, step: 1, min: 1,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
          </div>
          <%# on_site_time_hrs is stored but not yet used in the burden calculator.
              Hidden until the formula is confirmed with the business owner (Phase 7). %>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t("estimates.edit.profit_overhead_percent") %></label>
              <%= text_field_tag "estimate[profit_overhead_percent]", @estimate.profit_overhead_percent,
                  type: :number, step: "any", min: 0,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t("estimates.edit.pm_supervision_percent") %></label>
              <%= text_field_tag "estimate[pm_supervision_percent]", @estimate.pm_supervision_percent,
                  type: :number, step: "any", min: 0,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
          </div>
        </div>
        <%= hidden_field_tag "estimate[title]", @estimate.title %>
        <%= hidden_field_tag "estimate[client_id]", @estimate.client_id %>
        <div class="mt-4">
          <%= submit_tag t("estimates.edit.save_job_settings"),
              class: "w-full bg-slate-700 hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Sections with line items %>
  <div class="col-span-2">
    <% if @sections.any? %>
      <% @sections.each do |section| %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mb-4">
          <%# Section header %>
          <div class="flex items-center gap-3 px-6 py-3 border-b border-slate-200 bg-slate-50">
            <div class="flex flex-col gap-0.5">
              <%= button_to move_estimate_estimate_section_path(@estimate, section),
                  params: { direction: "up" },
                  method: :patch,
                  class: "text-slate-400 hover:text-slate-600 transition-colors bg-transparent border-0 p-0 cursor-pointer leading-none",
                  title: t("estimates.edit.move_up") do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
                </svg>
              <% end %>
              <%= button_to move_estimate_estimate_section_path(@estimate, section),
                  params: { direction: "down" },
                  method: :patch,
                  class: "text-slate-400 hover:text-slate-600 transition-colors bg-transparent border-0 p-0 cursor-pointer leading-none",
                  title: t("estimates.edit.move_down") do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              <% end %>
            </div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-slate-900">
                <%= section.name %>
                <span class="text-slate-400 font-normal text-xs ml-1">&times; <%= section.quantity %></span>
              </p>
              <p class="text-xs text-slate-500 mt-0.5">
                <%= t("estimates.edit.markup_label", percent: section.default_markup_percent) %>
                &middot;
                <%= t("estimates.edit.line_items_count", count: section.line_items_count) %>
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to t("common.edit"), edit_estimate_estimate_section_path(@estimate, section),
                  class: "text-slate-600 hover:text-amber-700 text-xs font-medium transition-colors" %>
              <% count = section.line_items_count %>
              <% confirm_msg = count > 0 ?
                  t("estimates.edit.confirm_delete_section_with_items", name: section.name, count: count) :
                  t("estimates.edit.confirm_delete_section", name: section.name) %>
              <%= button_to t("common.delete"), estimate_estimate_section_path(@estimate, section), method: :delete,
                  class: "text-red-500 hover:text-red-700 text-xs font-medium transition-colors bg-transparent border-0 p-0 cursor-pointer",
                  data: { turbo_confirm: confirm_msg } %>
            </div>
          </div>

          <%# Line items list %>
          <div id="line_items_<%= section.id %>">
            <% section.line_items.each do |line_item| %>
              <%= render "line_items/line_item", line_item: line_item, section: section, estimate: @estimate %>
            <% end %>
          </div>

          <%# Section subtotal %>
          <%= render "line_items/section_subtotal", section: section, subtotals: @totals.section_subtotals %>

          <%# New line item form %>
          <%= render "line_items/new_form", section: section, estimate: @estimate %>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-12 text-center mb-4">
        <p class="text-slate-500 text-sm"><%= t("estimates.edit.no_sections") %></p>
      </div>
    <% end %>

    <%# Estimate grand totals %>
    <%= render "line_items/estimate_totals", estimate: @estimate, totals: @totals %>

    <%# Add section form %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mt-4">
      <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
        <h3 class="text-sm font-semibold text-slate-700"><%= t("estimates.edit.add_section_heading") %></h3>
      </div>
      <div class="px-6 py-4">
        <%= form_with model: [ @estimate, @new_section ] do |f| %>
          <%# Validation errors are shown on the dedicated estimate_sections/new page.
              EstimateSectionsController#create re-renders that page on failure,
              not this inline form, so no error block is needed here. %>
          <div class="flex items-end gap-3">
            <div class="flex-1">
              <%= f.label :name, class: "block text-xs font-medium text-slate-700 mb-1" %>
              <%= f.text_field :name, required: true,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div class="w-20">
              <%= f.label :quantity, t("estimates.edit.quantity_field_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
              <%= f.number_field :quantity, min: 0.01, step: "any",
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div class="w-28">
              <%= f.label :default_markup_percent, t("estimates.edit.markup_field_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
              <%= f.number_field :default_markup_percent, min: 0, max: 999.99, step: 0.01,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <%= f.submit t("estimates.edit.add_section_button"), class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
