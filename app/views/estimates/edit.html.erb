<%# Materials setup banner — advisory only %>
<% if @estimate.estimate_materials.size.zero? %>
  <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-4 mb-6 flex items-center justify-between">
    <p class="text-sm text-amber-800">
      <%= t("estimates.materials_banner.message") %>
    </p>
    <%= link_to t("estimates.materials_banner.link"),
        estimate_estimate_materials_path(@estimate),
        class: "text-sm font-semibold text-amber-700 hover:text-amber-900 whitespace-nowrap ml-4 underline" %>
  </div>
<% end %>

<div class="grid grid-cols-3 gap-6">
  <%# Metadata / edit form %>
  <div class="col-span-1">
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t(".details_heading") %></h2>
      <%= form_with model: @estimate do |f| %>
        <%= render "form", f: f, estimate: @estimate %>
      <% end %>
    </div>

    <%# Status form (status-only update) %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t(".status_heading") %></h2>
      <%= form_with url: estimate_path(@estimate), method: :patch do |f| %>
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.select :status,
              Estimate.statuses.keys.map { |s| [ t("estimates.index.status_#{s}"), s ] },
              { selected: @estimate.status },
              name: "estimate[status]",
              class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
        </div>
        <%# hidden fields to satisfy validations %>
        <%= hidden_field_tag "estimate[title]", @estimate.title %>
        <%= hidden_field_tag "estimate[client_id]", @estimate.client_id %>
        <div class="mt-4">
          <%= f.submit t(".update_status"), class: "w-full bg-slate-700 hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%# Job settings form %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
      <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t(".job_settings_heading") %></h2>
      <%= form_with url: estimate_path(@estimate), method: :patch do |f| %>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".tax_rate") %></label>
            <%= text_field_tag "estimate[tax_rate]", @estimate.tax_rate,
                type: :number, step: "0.0001", min: 0, max: 1,
                class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
          </div>
          <div class="flex items-center gap-2">
            <%= check_box_tag "estimate[tax_exempt]", "1", @estimate.tax_exempt?,
                class: "rounded border-slate-300 text-amber-600 focus:ring-amber-500" %>
            <label class="text-xs font-medium text-slate-700"><%= t(".tax_exempt") %></label>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".miles_to_jobsite") %></label>
            <%= text_field_tag "estimate[miles_to_jobsite]", @estimate.miles_to_jobsite,
                type: :number, step: "any", min: 0,
                class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".installer_crew_size") %></label>
              <%= text_field_tag "estimate[installer_crew_size]", @estimate.installer_crew_size,
                  type: :number, step: 1, min: 1,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".delivery_crew_size") %></label>
              <%= text_field_tag "estimate[delivery_crew_size]", @estimate.delivery_crew_size,
                  type: :number, step: 1, min: 1,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".profit_overhead_percent") %></label>
              <%= text_field_tag "estimate[profit_overhead_percent]", @estimate.profit_overhead_percent,
                  type: :number, step: "any", min: 0,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1"><%= t(".pm_supervision_percent") %></label>
              <%= text_field_tag "estimate[pm_supervision_percent]", @estimate.pm_supervision_percent,
                  type: :number, step: "any", min: 0,
                  class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
            </div>
          </div>
        </div>
        <%= hidden_field_tag "estimate[title]", @estimate.title %>
        <%= hidden_field_tag "estimate[client_id]", @estimate.client_id %>
        <div class="mt-4">
          <%= submit_tag t(".save_job_settings"),
              class: "w-full bg-slate-700 hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Line items area %>
  <div class="col-span-2">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-slate-700"><%= t(".line_items_heading") %></h2>
      <%= link_to new_estimate_line_item_path(@estimate),
          class: "inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        <%= t(".add_product") %>
      <% end %>
    </div>

    <div id="line_items">
      <% if @estimate.line_items.any? %>
        <% @estimate.line_items.each do |line_item| %>
          <%= render "line_items/line_item", line_item: line_item, estimate: @estimate %>
        <% end %>
      <% else %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-12 text-center">
          <p class="text-slate-500 text-sm"><%= t(".no_line_items") %></p>
        </div>
      <% end %>
    </div>

    <%= render "line_items/estimate_totals", estimate: @estimate, totals: @totals %>
  </div>
</div>
