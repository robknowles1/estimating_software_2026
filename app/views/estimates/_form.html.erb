<% if estimate.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm" role="alert">
    <p class="font-semibold mb-1">
      <%= t("estimates.form.errors", count: estimate.errors.count) %>
    </p>
    <ul class="list-disc list-inside space-y-0.5 text-red-600">
      <% estimate.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-5">
  <div>
    <%= f.label :client_id, t("estimates.form.client"), class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.select :client_id,
        options_from_collection_for_select(@clients, :id, :company_name, estimate.client_id),
        { include_blank: t("estimates.form.select_client") },
        required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    <p class="text-xs text-slate-400 mt-1">
      <%= link_to t("estimates.form.new_client_link"), new_client_path, class: "text-amber-600 hover:text-amber-700" %>
    </p>
  </div>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :title, required: true,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :job_start_date, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.date_field :job_start_date,
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
    <div>
      <%= f.label :job_end_date, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.date_field :job_end_date,
          class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_area :notes, rows: 3,
        class: "w-full border border-slate-300 rounded-lg px-3.5 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
  </div>
</div>

<div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-200">
  <%= f.submit class: "bg-amber-600 hover:bg-amber-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
  <%= link_to t("estimates.form.cancel"), estimates_path, class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
</div>
