<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= t(".subtitle") %></p>
  </div>
  <%= link_to new_product_path,
      class: "inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
    </svg>
    <%= t(".new_button") %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @products.any? %>
    <table class="min-w-full">
      <thead>
        <tr class="border-b border-slate-200 bg-slate-50">
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t(".col_name") %></th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t(".col_category") %></th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t(".col_unit") %></th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t(".col_updated") %></th>
          <th class="px-6 py-3.5 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @products.each do |product| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-slate-900"><%= product.name %></td>
            <td class="px-6 py-4 text-sm text-slate-500">
              <%= product.category.presence || t("common.not_provided") %>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= product.unit %></td>
            <td class="px-6 py-4 text-sm text-slate-400"><%= product.updated_at.strftime("%b %-d, %Y") %></td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to t("common.edit"), edit_product_path(product),
                    class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-amber-700 text-sm font-medium transition-colors" %>
                <%= button_to t("common.delete"), product_path(product), method: :delete,
                    data: { turbo_confirm: t(".confirm_delete", name: product.name) },
                    class: "inline-flex items-center gap-1.5 text-red-500 hover:text-red-700 text-sm font-medium transition-colors bg-transparent border-0 p-0 cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
      <p class="text-slate-700 font-medium text-sm"><%= t(".empty_title") %></p>
      <p class="text-slate-400 text-sm mt-1"><%= t(".empty_description") %></p>
      <%= link_to t(".new_button"), new_product_path,
          class: "mt-4 inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" %>
    </div>
  <% end %>
</div>
