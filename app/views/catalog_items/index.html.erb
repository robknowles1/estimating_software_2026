<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-sm text-slate-500 mt-1"><%= t(".subtitle") %></p>
  </div>
  <%= link_to t(".add_button"), new_catalog_item_path,
      class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" %>
</div>

<%# Category filter %>
<% if @categories.any? %>
  <div class="flex items-center gap-2 mb-4 flex-wrap">
    <%= link_to t(".filter_all"), catalog_items_path,
        class: "px-3 py-1 rounded-full text-xs font-medium #{params[:category].blank? ? 'bg-amber-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'} transition-colors" %>
    <% @categories.each do |cat| %>
      <%= link_to cat.humanize, catalog_items_path(category: cat),
          class: "px-3 py-1 rounded-full text-xs font-medium #{params[:category] == cat ? 'bg-amber-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'} transition-colors" %>
    <% end %>
  </div>
<% end %>

<% if @catalog_items.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide"><%= t(".col_description") %></th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide"><%= t(".col_category") %></th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide"><%= t(".col_unit") %></th>
          <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide"><%= t(".col_cost") %></th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @catalog_items.each do |item| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 font-medium text-slate-900"><%= item.description %></td>
            <td class="px-4 py-3 text-slate-600"><%= item.category&.humanize || t("common.not_provided") %></td>
            <td class="px-4 py-3 text-slate-600"><%= item.default_unit.presence || t("common.not_provided") %></td>
            <td class="px-4 py-3 text-right text-slate-600">
              <%= item.default_unit_cost ? number_to_currency(item.default_unit_cost) : t("common.not_provided") %>
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to t("common.edit"), edit_catalog_item_path(item),
                    class: "text-xs text-amber-600 hover:text-amber-800 font-medium transition-colors" %>
                <%= button_to t("common.delete"), catalog_item_path(item), method: :delete,
                    form: { data: { turbo_confirm: t(".confirm_delete", description: item.description) } },
                    class: "text-xs text-red-600 hover:text-red-800 font-medium transition-colors bg-transparent border-0 cursor-pointer p-0" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl shadow-sm border border-slate-200">
    <p class="text-slate-500 font-medium"><%= t(".empty_title") %></p>
    <p class="text-sm text-slate-400 mt-1"><%= t(".empty_description") %></p>
  </div>
<% end %>
