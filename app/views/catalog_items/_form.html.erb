<%# locals: (catalog_item:) %>
<%= form_with model: catalog_item do |f| %>
  <% if catalog_item.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm" role="alert">
      <ul class="list-disc list-inside space-y-0.5 text-red-600">
        <% catalog_item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= f.label :description, t(".description_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_field :description, required: true,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :default_unit, t(".unit_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.text_field :default_unit, placeholder: t(".unit_placeholder"),
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :default_unit_cost, t(".unit_cost_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :default_unit_cost, step: "0.01", min: 0,
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
    </div>

    <div>
      <%= f.label :category, t(".category_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_field :category, placeholder: t(".category_placeholder"),
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
  </div>

  <div class="flex items-center gap-3 mt-6">
    <%= f.submit catalog_item.persisted? ? t(".update_button") : t(".create_button"),
        class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
    <%= link_to t(".cancel"), catalog_items_path,
        class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
  </div>
<% end %>
