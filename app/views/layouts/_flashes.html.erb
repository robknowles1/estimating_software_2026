<% if notice %>
  <div class="bg-emerald-50 border-b border-emerald-200 text-emerald-800 px-6 py-3 text-sm flex items-center gap-2" role="status">
    <svg class="w-4 h-4 flex-shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
    <%= notice %>
  </div>
<% end %>

<% if alert %>
  <div class="bg-red-50 border-b border-red-200 text-red-800 px-6 py-3 text-sm flex items-center gap-2" role="alert">
    <svg class="w-4 h-4 flex-shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 110 18A9 9 0 0112 3z"/>
    </svg>
    <%= alert %>
  </div>
<% end %>
