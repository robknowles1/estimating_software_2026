<aside class="w-60 bg-slate-900 flex flex-col flex-shrink-0">

  <%# Brand %>
  <div class="px-6 py-5 border-b border-slate-800">
    <p class="text-amber-500 text-xs uppercase tracking-widest font-semibold"><%= t("app.company") %></p>
    <p class="text-white font-semibold text-sm leading-snug mt-1"><%= t("app.name") %></p>
  </div>

  <%# Navigation %>
  <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

    <%# Active state uses controller_name so / (root → estimates#index)
        and nested routes (/estimates/new etc.) all highlight correctly. %>
    <% nav_link = ->(label, path, ctrl, icon) do
         # ctrl may be a String or an Array of controller names (e.g. clients + contacts)
         active = Array(ctrl).include?(controller_name)
         base = "flex items-center gap-3 px-3 py-2 rounded text-sm font-medium transition-colors"
         cls  = active ? "#{base} bg-slate-800 text-white" : "#{base} text-slate-400 hover:bg-slate-800 hover:text-white"
    %>
      <%= link_to path, class: cls do %>
        <%= icon.html_safe %>
        <%= label %>
      <% end %>
    <% end %>

    <% nav_link.call(t("nav.estimates"), estimates_path, "estimates",
         '<svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>') %>

    <% nav_link.call(t("nav.clients"), clients_path, %w[clients contacts],
         '<svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>') %>

    <% nav_link.call(t("nav.users"), users_path, "users",
         '<svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5.356-3.779M9 20H4v-2a4 4 0 015.356-3.779M15 7a4 4 0 11-8 0 4 4 0 018 0zm6 3a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>') %>

  </nav>

  <%# User + Logout %>
  <div class="px-4 py-4 border-t border-slate-800">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-7 h-7 rounded-full bg-amber-600 flex items-center justify-center flex-shrink-0">
        <span class="text-white text-xs font-bold"><%= current_user&.name&.first&.upcase || "?" %></span>
      </div>
      <span class="text-slate-300 text-sm truncate"><%= current_user.name %></span>
    </div>
    <%= button_to session_path, method: :delete,
        class: "w-full flex items-center gap-2 px-3 py-2 rounded text-sm text-slate-500 hover:bg-slate-800 hover:text-slate-300 transition-colors" do %>
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
      </svg>
      <%= t("nav.sign_out") %>
    <% end %>
  </div>

</aside>
