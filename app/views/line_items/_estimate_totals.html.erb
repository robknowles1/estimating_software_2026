<div id="estimate_<%= estimate.id %>_totals" class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 mt-4">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide"><%= t(".grand_non_burdened_label") %></p>
      <p class="text-2xl font-bold text-slate-800"><%= number_to_currency(totals.grand_non_burdened_total) %></p>
      <p class="text-xs text-slate-400 mt-1"><%= t(".burden_note") %></p>
    </div>
    <div class="text-right">
      <p class="text-xs text-slate-500"><%= t(".burden_multiplier_label") %></p>
      <p class="text-sm font-medium text-slate-600"><%= number_with_precision(totals.burden_multiplier, precision: 3) %>×</p>
    </div>
  </div>
</div>
