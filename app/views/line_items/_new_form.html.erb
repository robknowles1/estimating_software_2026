<%# locals: (section:, estimate:) %>
<div id="line_item_form_<%= section.id %>" class="px-6 py-4 border-t border-slate-200 bg-slate-50">
  <h4 class="text-xs font-semibold text-slate-600 mb-3"><%= t("line_items.add_line_item_heading") %></h4>
  <%= render "line_items/form",
      line_item: section.line_items.build(line_item_category: "material"),
      section: section,
      estimate: estimate %>
</div>
