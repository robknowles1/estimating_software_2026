<%# Remove the line item row %>
<%= turbo_stream.remove dom_id(@line_item) %>

<%# Update the section subtotal %>
<%= turbo_stream.replace dom_id(@section, :subtotal),
    partial: "line_items/section_subtotal",
    locals: { section: @section, subtotals: @totals.section_subtotals } %>

<%# Update the estimate grand total %>
<%= turbo_stream.replace dom_id(@estimate, :totals),
    partial: "line_items/estimate_totals",
    locals: { estimate: @estimate, totals: @totals } %>
