<%= form_with model: [estimate, line_item], data: { turbo: true } do |f| %>
  <%# Core fields %>
  <div class="grid grid-cols-3 gap-4 mb-5">
    <div class="col-span-2">
      <%= f.label :description, class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_field :description, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :quantity, class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.number_field :quantity, step: "any", min: 0.001, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :unit, class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_field :unit, placeholder: "ea, LF, SF…", class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" %>
    </div>
  </div>

  <%# Validation errors %>
  <% if line_item.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-3">
      <ul class="text-xs text-red-700 space-y-1 list-disc list-inside">
        <% line_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Build grouped options once %>
  <% sheet_goods = materials.select { |m| m.category == "sheet_good" } %>
  <% hardware    = materials.select { |m| m.category == "hardware"   } %>
  <% grouped_options = grouped_options_for_select([
       ["Sheet Goods", sheet_goods.map { |m| [m.display_label, m.id] }],
       ["Hardware",    hardware.map    { |m| [m.display_label, m.id] }]
     ]) %>

  <%# Material section %>
  <div class="mb-5">
    <h4 class="text-xs font-semibold text-slate-600 uppercase tracking-wide mb-3"><%= t(".materials_heading") %></h4>
    <div class="grid grid-cols-2 gap-3">
      <%# Exterior — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".exterior_qty") %></label>
          <%= f.number_field :exterior_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".exterior_material") %></label>
          <%= f.select :exterior_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Interior — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".interior_qty") %></label>
          <%= f.number_field :interior_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".interior_material") %></label>
          <%= f.select :interior_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Interior 2 — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".interior2_qty") %></label>
          <%= f.number_field :interior2_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".interior2_material") %></label>
          <%= f.select :interior2_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Back — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".back_qty") %></label>
          <%= f.number_field :back_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".back_material") %></label>
          <%= f.select :back_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Banding — dropdown ONLY, no qty (ADR-008 OQ-B) %>
      <div>
        <label class="block text-xs text-slate-600 mb-1"><%= t(".banding_material") %></label>
        <%= f.select :banding_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
      </div>
      <%# Drawers — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".drawers_qty") %></label>
          <%= f.number_field :drawers_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".drawers_material") %></label>
          <%= f.select :drawers_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Pulls — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".pulls_qty") %></label>
          <%= f.number_field :pulls_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".pulls_material") %></label>
          <%= f.select :pulls_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Hinges — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".hinges_qty") %></label>
          <%= f.number_field :hinges_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".hinges_material") %></label>
          <%= f.select :hinges_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Slides — qty + dropdown %>
      <div class="flex gap-2 items-end">
        <div class="w-20 flex-shrink-0">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".slides_qty") %></label>
          <%= f.number_field :slides_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs text-slate-600 mb-1"><%= t(".slides_material") %></label>
          <%= f.select :slides_material_id, grouped_options, { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      </div>
      <%# Locks — qty ONLY, no dropdown (ADR-008) %>
      <div>
        <label class="block text-xs text-slate-600 mb-1"><%= t(".locks_qty") %></label>
        <%= f.number_field :locks_qty, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
      </div>
      <%# Other material cost %>
      <div>
        <label class="block text-xs text-slate-600 mb-1"><%= t(".other_material_cost") %></label>
        <%= f.number_field :other_material_cost, step: "0.01", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
      </div>
    </div>
  </div>

  <%# Labor section %>
  <div class="mb-5">
    <h4 class="text-xs font-semibold text-slate-600 uppercase tracking-wide mb-3"><%= t(".labor_heading") %></h4>
    <div class="grid grid-cols-3 gap-3">
      <% %w[detail mill assembly customs finish install].each do |cat| %>
        <div>
          <label class="block text-xs text-slate-600 mb-1"><%= t(".#{cat}_hrs") %></label>
          <%= f.number_field :"#{cat}_hrs", step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Equipment section %>
  <div class="mb-5">
    <h4 class="text-xs font-semibold text-slate-600 uppercase tracking-wide mb-3"><%= t(".equipment_heading") %></h4>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-slate-600 mb-1"><%= t(".equipment_hrs") %></label>
        <%= f.number_field :equipment_hrs, step: "any", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
      </div>
      <div>
        <label class="block text-xs text-slate-600 mb-1"><%= t(".equipment_rate") %></label>
        <%= f.number_field :equipment_rate, step: "0.01", min: 0, class: "w-full border border-slate-300 rounded-lg px-2 py-2 text-sm" %>
      </div>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit line_item.new_record? ? t(".add_product") : t(".save_product"),
        class: "bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
    <% if line_item.persisted? %>
      <button type="button" data-action="line-item-accordion#toggle"
              class="text-sm text-slate-500 hover:text-slate-700 px-3 py-2">
        <%= t(".cancel") %>
      </button>
    <% end %>
  </div>
<% end %>
