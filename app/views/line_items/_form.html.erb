<%# Shared field style helpers %>
<% input_cls = "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
<% label_cls = "block text-xs font-medium text-slate-700 mb-1" %>

<%# Validation errors %>
<% if f.object.errors.any? %>
  <div class="bg-red-50 border border-red-300 rounded-lg p-4 mb-6">
    <p class="text-sm font-semibold text-red-700 mb-2">
      <%= t("line_items.form.errors", count: f.object.errors.count) %>
    </p>
    <ul class="list-disc list-inside space-y-1">
      <% f.object.errors.each do |error| %>
        <li class="text-sm text-red-600"><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%# ── Product selector ── %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-3"><%= t("line_items.form.select_product") %></h2>
  <select name="line_item[product_id]"
          data-product-selector-target="select"
          data-action="change->product-selector#fill"
          class="<%= input_cls %>">
    <option value=""><%= t("line_items.form.freeform_option") %></option>
    <% products.group_by(&:category).each do |category, prods| %>
      <optgroup label="<%= category.presence || 'Uncategorized' %>">
        <% prods.each do |product| %>
          <option value="<%= product.id %>" <%= "selected" if f.object.product_id == product.id %>>
            <%= product.name %>
          </option>
        <% end %>
      </optgroup>
    <% end %>
  </select>
</div>

<%# ── Identity ── %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("line_items.form.identity_heading") %></h2>
  <div class="grid grid-cols-3 gap-4">
    <div class="col-span-2">
      <%= f.label :description, class: label_cls %>
      <%= f.text_field :description, class: input_cls, placeholder: "e.g. MDF Base 2-door" %>
    </div>
    <div>
      <%= f.label :unit, class: label_cls %>
      <%= f.text_field :unit, class: input_cls, placeholder: "EA" %>
    </div>
    <div>
      <%= f.label :quantity, class: label_cls %>
      <%= f.number_field :quantity, class: input_cls, step: "0.0001", min: 0.0001 %>
    </div>
  </div>
</div>

<%# ── Materials ── %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("line_items.form.materials_heading") %></h2>

  <%# Column headers %>
  <div class="grid grid-cols-12 gap-2 mb-2 px-1">
    <div class="col-span-1"></div>
    <div class="col-span-5 text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t("line_items.form.material_description_col") %></div>
    <div class="col-span-3 text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t("line_items.form.material_unit_price_col") %></div>
    <div class="col-span-3 text-xs font-semibold text-slate-500 uppercase tracking-wider"><%= t("line_items.form.material_qty_col") %></div>
  </div>

  <% [
    { key: :exterior,  label: t("line_items.form.material_slot_exterior") },
    { key: :interior,  label: t("line_items.form.material_slot_interior") },
    { key: :interior2, label: t("line_items.form.material_slot_interior2") },
    { key: :back,      label: t("line_items.form.material_slot_back") },
    { key: :drawers,   label: t("line_items.form.material_slot_drawers") },
    { key: :pulls,     label: t("line_items.form.material_slot_pulls") },
    { key: :hinges,    label: t("line_items.form.material_slot_hinges") },
    { key: :slides,    label: t("line_items.form.material_slot_slides") },
    { key: :locks,     label: t("line_items.form.material_slot_locks") }
  ].each do |slot| %>
    <div class="grid grid-cols-12 gap-2 mb-2 items-center">
      <div class="col-span-1 text-xs text-slate-500 font-medium"><%= slot[:label] %></div>
      <div class="col-span-5">
        <%= f.text_field :"#{slot[:key]}_description", class: input_cls %>
      </div>
      <div class="col-span-3">
        <%= f.number_field :"#{slot[:key]}_unit_price", class: input_cls, step: "0.0001", min: 0 %>
      </div>
      <div class="col-span-3">
        <%= f.number_field :"#{slot[:key]}_qty", class: input_cls, step: "0.0001", min: 0 %>
      </div>
    </div>
  <% end %>

  <%# Banding — no qty %>
  <div class="grid grid-cols-12 gap-2 mb-2 items-center">
    <div class="col-span-1 text-xs text-slate-500 font-medium"><%= t("line_items.form.material_slot_banding") %></div>
    <div class="col-span-5">
      <%= f.text_field :banding_description, class: input_cls %>
    </div>
    <div class="col-span-3">
      <%= f.number_field :banding_unit_price, class: input_cls, step: "0.0001", min: 0 %>
    </div>
    <div class="col-span-3">
      <span class="text-xs text-slate-400 italic"><%= t("line_items.form.banding_flat_rate") %></span>
    </div>
  </div>

  <%# Other material cost %>
  <div class="mt-4 pt-4 border-t border-slate-100">
    <div class="grid grid-cols-12 gap-2 items-center">
      <div class="col-span-4 text-xs font-medium text-slate-700"><%= t("line_items.form.other_material_cost_label") %></div>
      <div class="col-span-3">
        <%= f.number_field :other_material_cost, class: input_cls, step: "0.01", min: 0 %>
      </div>
    </div>
  </div>
</div>

<%# ── Labor ── %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("line_items.form.labor_heading") %></h2>
  <div class="grid grid-cols-3 gap-4">
    <% %w[detail mill assembly customs finish install].each do |cat| %>
      <div>
        <label class="<%= label_cls %>"><%= t("line_items.form.labor_#{cat}_hrs") %></label>
        <%= f.number_field :"#{cat}_hrs", class: input_cls, step: "0.0001", min: 0 %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Equipment ── %>
<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-4"><%= t("line_items.form.equipment_heading") %></h2>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="<%= label_cls %>"><%= t("line_items.form.equipment_hrs_label") %></label>
      <%= f.number_field :equipment_hrs, class: input_cls, step: "0.0001", min: 0 %>
    </div>
    <div>
      <label class="<%= label_cls %>"><%= t("line_items.form.equipment_rate_label") %></label>
      <%= f.number_field :equipment_rate, class: input_cls, step: "0.01", min: 0 %>
    </div>
  </div>
</div>

<%# ── Actions ── %>
<div class="flex items-center gap-3">
  <%= f.submit class: "bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
  <%= link_to t("line_items.form.cancel"), edit_estimate_path(estimate),
      class: "text-sm text-slate-600 hover:text-slate-900 font-medium" %>
</div>
