<%# locals: (line_item:, section:, estimate:) %>
<% url = line_item.persisted? ? estimate_estimate_section_line_item_path(estimate, section, line_item) : estimate_estimate_section_line_items_path(estimate, section) %>
<% method = line_item.persisted? ? :patch : :post %>

<%= form_with model: line_item, url: url, method: method,
    data: { controller: "line-item-calculator" } do |f| %>

  <% if line_item.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm" role="alert">
      <ul class="list-disc list-inside space-y-0.5 text-red-600">
        <% line_item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :line_item_category, t("line_items.form.category_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.select :line_item_category,
            LineItem::LINE_ITEM_CATEGORIES.map { |c| [ t("line_items.category.#{c}"), c ] },
            { selected: line_item.line_item_category || "material" },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div id="component_type_field">
        <%= f.label :component_type, t("line_items.form.component_type_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.select :component_type,
            [[ t("line_items.form.select_blank"), "" ]] + LineItem::COMPONENT_TYPES.map { |c| [ c.humanize, c ] },
            { selected: line_item.component_type },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
    </div>

    <div>
      <%= f.label :description, t("line_items.form.description_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_field :description, required: true,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :estimate_material_id, t("line_items.form.material_slot_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%# Sort in Ruby so a preloaded association is not re-queried per section %>
        <% materials = estimate.estimate_materials.sort_by { |m| [m.category, m.slot_number] } %>
        <%= f.select :estimate_material_id,
            [[ t("line_items.form.no_material_slot"), "" ]] +
            materials.map { |m| [ "#{m.slot_label}#{m.description.present? ? " — #{m.description}" : ""} (#{number_to_currency(m.price_per_unit)})", m.id ] },
            { selected: line_item.estimate_material_id },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :labor_category, t("line_items.form.labor_category_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.select :labor_category,
            [[ t("line_items.form.select_blank"), "" ]] + LineItem::LABOR_CATEGORIES.map { |c| [ c.humanize, c ] },
            { selected: line_item.labor_category },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= f.label :component_quantity, t("line_items.form.component_quantity_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :component_quantity, step: "any", min: 0,
            data: { "line-item-calculator-target" => "componentQuantityInput" },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :hours_per_unit, t("line_items.form.hours_per_unit_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :hours_per_unit, step: "any", min: 0,
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :freeform_quantity, t("line_items.form.freeform_quantity_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :freeform_quantity, step: "any", min: 0,
            data: { "line-item-calculator-target" => "quantityInput", action: "input->line-item-calculator#calculate" },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= f.label :unit_cost, t("line_items.form.unit_cost_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :unit_cost, step: "any", min: 0,
            data: { "line-item-calculator-target" => "unitCostInput", action: "input->line-item-calculator#calculate" },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :markup_percent, t("line_items.form.markup_percent_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.number_field :markup_percent, step: "any", min: 0,
            data: { "line-item-calculator-target" => "markupInput", action: "input->line-item-calculator#calculate" },
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
      <div>
        <%= f.label :unit, t("line_items.form.unit_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.text_field :unit,
            class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
      </div>
    </div>

    <%# Real-time extended cost display %>
    <div class="flex items-center justify-between px-3 py-2 bg-slate-50 rounded-lg border border-slate-200">
      <span class="text-xs text-slate-500"><%= t("line_items.form.extended_cost_preview") %></span>
      <span class="text-sm font-semibold text-slate-900" data-line-item-calculator-target="extendedCostDisplay">—</span>
      <span class="text-xs text-slate-500 ml-4"><%= t("line_items.form.sell_price_preview") %></span>
      <span class="text-sm font-semibold text-amber-700" data-line-item-calculator-target="sellPriceDisplay">—</span>
    </div>

    <div>
      <%= f.label :notes, t("line_items.form.notes_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
      <%= f.text_area :notes, rows: 2,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors" %>
    </div>
  </div>

  <div class="flex items-center gap-3 mt-4">
    <%= f.submit line_item.persisted? ? t("line_items.form.update_button") : t("line_items.form.create_button"),
        class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
    <%= link_to t("line_items.form.cancel"),
        edit_estimate_path(estimate),
        class: "text-sm text-slate-500 hover:text-slate-700 font-medium transition-colors" %>
  </div>
<% end %>
