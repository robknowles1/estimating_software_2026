<%# locals: (section:, subtotals:) %>
<% sb = subtotals[section.id] || { non_burdened: BigDecimal("0"), burdened: BigDecimal("0") } %>
<div id="<%= dom_id(section, :subtotal) %>" class="flex items-center justify-between px-6 py-3 bg-slate-50 border-t border-slate-200">
  <div class="flex items-center gap-3">
    <span class="text-sm font-semibold text-slate-700"><%= section.name %></span>
    <span class="text-xs text-slate-500"><%= t("line_items.section_quantity", count: number_with_precision(section.quantity, strip_insignificant_zeros: true)) %></span>
  </div>
  <div class="flex items-center gap-6 text-sm">
    <div class="text-right">
      <p class="text-xs text-slate-500"><%= t("line_items.non_burdened_label") %></p>
      <p class="font-semibold text-slate-900"><%= number_to_currency(sb[:non_burdened]) %></p>
    </div>
    <div class="text-right">
      <p class="text-xs text-slate-500"><%= t("line_items.burdened_label") %></p>
      <p class="font-semibold text-amber-700"><%= number_to_currency(sb[:burdened]) %></p>
    </div>
  </div>
</div>
