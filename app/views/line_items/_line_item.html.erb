<%# locals: (line_item:, section:, estimate:) %>
<div id="<%= dom_id(line_item) %>" class="flex items-start gap-3 px-6 py-3 border-b border-slate-100 last:border-0 group">
  <%# Reorder controls %>
  <div class="flex flex-col gap-0.5 pt-1 shrink-0">
    <%= button_to move_estimate_estimate_section_line_item_path(estimate, section, line_item),
        params: { direction: "up" },
        method: :patch,
        class: "text-slate-300 hover:text-slate-600 bg-transparent border-0 p-0 cursor-pointer leading-none transition-colors",
        title: t("line_items.move_up") do %>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
      </svg>
    <% end %>
    <%= button_to move_estimate_estimate_section_line_item_path(estimate, section, line_item),
        params: { direction: "down" },
        method: :patch,
        class: "text-slate-300 hover:text-slate-600 bg-transparent border-0 p-0 cursor-pointer leading-none transition-colors",
        title: t("line_items.move_down") do %>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    <% end %>
  </div>

  <%# Category badge %>
  <div class="shrink-0 pt-0.5">
    <span class="inline-block px-1.5 py-0.5 text-xs rounded font-medium <%= line_item_category_class(line_item.line_item_category) %>">
      <%= t("line_items.category.#{line_item.line_item_category}") %>
    </span>
  </div>

  <%# Main content %>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium text-slate-900 truncate"><%= line_item.description %></p>
    <p class="text-xs text-slate-500 mt-0.5">
      <% if line_item.line_item_category == "material" %>
        <%= line_item.component_type&.humanize %>
        <% if line_item.estimate_material.present? %>
          &middot; <%= line_item.estimate_material.slot_label %>
          <% if line_item.estimate_material.description.present? %>
            (<%= line_item.estimate_material.description %>)
          <% end %>
          &middot; <%= number_to_currency(line_item.estimate_material.price_per_unit) %>/unit
        <% end %>
        <% if line_item.component_quantity.present? %>
          &middot; <%= line_item.component_quantity %> per cabinet
        <% end %>
      <% elsif line_item.line_item_category == "labor" %>
        <%= line_item.labor_category&.humanize %>
        <% if line_item.hours_per_unit.present? %>
          &middot; <%= format("%.3f", line_item.hours_per_unit) %> hrs/cabinet
        <% end %>
      <% else %>
        <% if line_item.freeform_quantity.present? %>
          Qty: <%= line_item.freeform_quantity %>
        <% end %>
        <% if line_item.unit_cost.present? && line_item.unit_cost > 0 %>
          &middot; <%= number_to_currency(line_item.unit_cost) %>/unit
        <% end %>
        <% if line_item.markup_percent.present? && line_item.markup_percent > 0 %>
          &middot; <%= line_item.markup_percent %>% markup
        <% end %>
      <% end %>
    </p>
  </div>

  <%# Extended cost — labor cost is computed by EstimateTotalsCalculator (with preloaded rates),
      not per-row here, to avoid N+1 queries. Material cost is safe: estimate_material is preloaded. %>
  <div class="shrink-0 text-right">
    <% if line_item.line_item_category == "labor" %>
      <p class="text-sm text-slate-400">—</p>
      <p class="text-xs text-slate-400"><%= t("line_items.see_section_total") %></p>
    <% else %>
      <p class="text-sm font-semibold text-slate-900"><%= number_to_currency(line_item.extended_cost) %></p>
      <% if %w[alternate buy_out].include?(line_item.line_item_category) %>
        <p class="text-xs text-slate-500">sell: <%= number_to_currency(line_item.sell_price) %></p>
      <% end %>
    <% end %>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-2 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= link_to t("common.edit"),
        edit_estimate_estimate_section_line_item_path(estimate, section, line_item),
        class: "text-slate-500 hover:text-amber-700 text-xs font-medium transition-colors" %>
    <%= button_to t("common.delete"),
        estimate_estimate_section_line_item_path(estimate, section, line_item),
        method: :delete,
        class: "text-slate-500 hover:text-red-600 text-xs font-medium transition-colors bg-transparent border-0 p-0 cursor-pointer",
        data: { turbo_confirm: t("line_items.confirm_delete") } %>
  </div>
</div>
