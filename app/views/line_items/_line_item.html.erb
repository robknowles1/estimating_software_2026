<div id="<%= dom_id(line_item) %>" class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 mb-3">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-sm font-semibold text-slate-900"><%= line_item.description %></span>
        <span class="text-xs text-slate-400 font-mono"><%= line_item.quantity %> <%= line_item.unit %></span>
      </div>
      <% if line_item.product.present? %>
        <p class="text-xs text-slate-400 italic"><%= t("line_items.line_item.based_on", product: line_item.product.name) %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <%= link_to t("common.edit"), edit_estimate_line_item_path(estimate, line_item),
          class: "text-xs text-slate-500 hover:text-amber-700 font-medium transition-colors" %>
      <%= button_to t("common.delete"), estimate_line_item_path(estimate, line_item), method: :delete,
          form: { data: { turbo: false, turbo_confirm: t("line_items.line_item.confirm_delete") } },
          class: "text-xs text-red-400 hover:text-red-600 font-medium transition-colors bg-transparent border-0 p-0 cursor-pointer" %>
    </div>
  </div>
</div>
