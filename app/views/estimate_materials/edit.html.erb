<div class="max-w-xl mx-auto">
  <div class="mb-6">
    <h1 class="text-xl font-bold text-slate-900"><%= t(".title") %></h1>
    <p class="text-sm text-slate-500 mt-0.5"><%= t(".subtitle", name: @estimate_material.material.name) %></p>
  </div>

  <%= form_with model: [@estimate, @estimate_material] do |f| %>
    <%= render "form", f: f, estimate: @estimate %>
  <% end %>
</div>
